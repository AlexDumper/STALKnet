# Production переменные окружения для STALKnet
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ КАК .env.production И ЗАПОЛНИТЕ СВОИМИ ДАННЫМИ
# НЕ КОММИТЬТЕ .env.production В GIT!

# =============================================================================
# БАЗА ДАННЫХ (PostgreSQL)
# =============================================================================
DB_USER=stalknet
DB_PASSWORD=ИЗМЕНИТЕ_ЭТОТ_ПАРОЛЬ_НА_СЛОЖНЫЙ
DB_NAME=stalknet

# =============================================================================
# JWT СЕКРЕТ (ОБЯЗАТЕЛЬНО ИЗМЕНИТЕ!)
# =============================================================================
# Сгенерируйте случайную строку минимум 32 символа
# Пример команды для генерации: openssl rand -base64 32
JWT_SECRET=ИЗМЕНИТЕ_ЭТОТ_СЕКРЕТ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА

# =============================================================================
# ПОРТЫ СЕРВИСОВ
# =============================================================================
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
CHAT_PORT=8083
TASK_PORT=8084
NOTIFICATION_PORT=8085

# =============================================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# =============================================================================
# Домен приложения (для CORS и HTTPS)
APP_DOMAIN=localhost
# APP_DOMAIN=yourdomain.com

# Режим (production/staging/development)
APP_ENV=production

# Логирование (debug/info/warn/error)
LOG_LEVEL=info
